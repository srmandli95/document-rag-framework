APP_NAME=PersonalPolicyRagAssistant
ENV=local

DATABASE_URL=postgresql+psycopg2://personal_policy_rag_assistant:personal_policy_rag_assistant@postgres:5432/personal_policy_rag_assistant
ASYNC_DATABASE_URL=postgresql+asyncpg://personal_policy_rag_assistant:personal_policy_rag_assistant@postgres:5432/personal_policy_rag_assistant

STORAGE_PROVIDER=local
RAW_DOCUMENTS_DIR=/app/data/raw_documents
REDACTED_DOCUMENTS_DIR=/app/data/redacted_documents
EXTRACTED_TEXT_DIR=/app/data/extracted_text
PROCESSED_CHUNKS_DIR=/app/data/processed_chunks
MAX_UPLOAD_SIZE_MB=25

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

RERANKER_PROVIDER=local
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_TOP_K=8

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini
ANSWER_TOP_K=5

# Chainlit UI
BACKEND_API_URL=http://backend:8000
CHAINLIT_AUTH_SECRET=change_me_later
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth - optional; required only for /auth/google/* endpoints
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback
